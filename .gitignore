# Data — never commit raw imaging data or large processed files
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep
results/*
!results/.gitkeep
*.tif
*.tiff
*.h5
*.h5ad
*.zarr/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Build / packaging
build/
dist/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/

# Environments
.env
*.egg
.venv/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/

# Claude Code local state
.claude/settings.local.json
.claude/worktrees/
